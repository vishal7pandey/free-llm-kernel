# ──────────────────────────────────────────────
# Free LLM Provider API Keys
# Copy this file to .env and fill in the keys you have.
# You only need ONE key to start. Add more for better fallback.
# All providers below have free tiers — no credit card required.
# ──────────────────────────────────────────────

# Groq — 1,000 req/day, 30 RPM, Llama-3.3-70B, very fast
# Get key: https://console.groq.com/keys
GROQ_API_KEY=your-key-here

# Google AI Studio (Gemini) — 1,500 req/day, 1M token context
# Get key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-key-here

# Cerebras — 1M tokens/day free, very fast
# Get key: https://cloud.cerebras.ai
CEREBRAS_API_KEY=your-key-here

# Mistral — 1B tokens/month, 2 RPM (good for batch)
# Get key: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your-key-here

# SambaNova — free tier, Llama-3.3-70B
# Get key: https://cloud.sambanova.ai
SAMBANOVA_API_KEY=your-key-here

# Cohere — trial key, Command R+
# Get key: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your-key-here

# OpenRouter — 50 req/day free, 20+ models
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-key-here

# NVIDIA NIM — 40 RPM free credits
# Get key: https://build.nvidia.com
NVIDIA_API_KEY=your-key-here

# Cloudflare Workers AI — 10k neurons/day
# Get token: https://dash.cloudflare.com/profile/api-tokens
# Get account ID: https://dash.cloudflare.com (right sidebar)
CLOUDFLARE_API_TOKEN=your-key-here
CF_ACCOUNT_ID=your-account-id-here

# Ollama (local) — no key needed, just run `ollama serve`
# Download: https://ollama.com
OLLAMA_API_KEY=ollama
